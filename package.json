{
  "name": "conjure-svelte",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "dev": "run-p -r dev:serve check:watch lint:watch",
    "dev:serve": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "pnpm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "lint:watch": "chokidar -c \"eslint .\" --silent --initial \"src/**/*.svelte\" \"src/**/*.ts\"",
    "prepare": "husky",
    "test:unit": "vitest",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/bxs": "^1.2.3",
    "@iconify-json/carbon": "^1.2.24",
    "@iconify-json/emojione": "^1.2.3",
    "@iconify-json/fxemoji": "^1.2.2",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/material-symbols": "^1.2.83",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/noto": "^1.2.7",
    "@iconify-json/openmoji": "^1.2.27",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/solar": "^1.2.5",
    "@iconify-json/tabler": "^1.2.35",
    "@iconify-json/vscode-icons": "^1.2.66",
    "@standard-schema/spec": "^1.1.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@sveltepress/theme-default": "^7.3.3",
    "@sveltepress/vite": "^1.3.12",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "autoprefixer": "^10.5.2",
    "chokidar-cli": "^3.0.0",
    "clsx": "^2.1.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "publint": "^0.3.21",
    "shiki": "^4.3.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-preprocess": "^6.0.5",
    "svelte2tsx": "^0.7.57",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "valibot": "^1.4.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">= 22.0.0"
  },
  "packageManager": "pnpm@11.11.0"
}
